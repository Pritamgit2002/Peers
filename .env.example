# PostgreSQL (local Docker default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bigfile

# API server
PORT=3001
WS_PORT=3002
CLIENT_ORIGIN=http://localhost:3000

# Web app (Next.js)
NEXT_PUBLIC_WS_URL=ws://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3001

# Clerk (https://dashboard.clerk.com/)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Cloudflare R2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# TUS upload URLs returned to the browser (Next.js proxy prefix)
TUS_PUBLIC_PREFIX=/backend
